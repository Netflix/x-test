{
  "name": "@netflix/x-test",
  "description": "a simple, tap-compliant test runner for the browser",
  "version": "2.0.0-rc.9",
  "license": "Apache-2.0",
  "repository": "https://github.com/Netflix/x-test",
  "type": "module",
  "exports": {
    ".": {
      "types": "./types/x-test.d.ts",
      "default": "./x-test.js"
    },
    "./x-test.js": {
      "types": "./types/x-test.d.ts",
      "default": "./x-test.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "node ./server.js",
    "lint": "eslint --max-warnings=0 .",
    "lint-fix": "eslint --fix .",
    "test": "x-test",
    "type": "tsc",
    "bump": "./bump.sh"
  },
  "files": [
    "/x-test-common.js",
    "/x-test-reporter.css.js",
    "/x-test-reporter.js",
    "/x-test-root.js",
    "/x-test-frame.js",
    "/x-test-tap.js",
    "/x-test.js",
    "/demo",
    "/test",
    "/types"
  ],
  "devDependencies": {
    "@netflix/eslint-config": "3.0.0",
    "@netflix/x-test-cli": "1.0.0-rc.6",
    "eslint": "10.1.0",
    "eslint-plugin-jsdoc": "62.8.0",
    "globals": "17.4.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.8"
  },
  "contributors": [
    {
      "name": "Andrew Seier",
      "email": "aseier@netflix.com"
    },
    {
      "name": "Casey Klebba",
      "email": "cklebba@netflix.com"
    }
  ]
}
